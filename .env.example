# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored — never commit real credentials.
#
# These values are required for local development (and for Netlify they are
# already set in netlify.toml under [build.environment]).

# Base44 app identifier (no secrets — found in your Base44 dashboard)
VITE_BASE44_APP_ID=69dfb5d1674e81512478f6f7

# Base44 app base URL — enables the Vite dev proxy so API calls work on localhost
VITE_BASE44_APP_BASE_URL=https://flexyn.base44.app

# Optional: pin a specific Base44 functions runtime version
# VITE_BASE44_FUNCTIONS_VERSION=
