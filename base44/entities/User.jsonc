{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "country_code": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code (e.g. 'US', 'GB')"
    },
    "state_code": {
      "type": "string",
      "description": "USPS state abbreviation \u2014 only set when country_code is 'US'"
    }
  }
}