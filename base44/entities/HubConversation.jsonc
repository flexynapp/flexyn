{
  "name": "HubConversation",
  "type": "object",
  "properties": {
    "participant_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Participant emails \u2014 stored with exact auth casing"
    },
    "participant_key": {
      "type": "string",
      "description": "Sorted lowercased emails joined with | \u2014 stable dedup key"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_message_preview": {
      "type": "string",
      "description": "First 80 chars of last message for inbox preview"
    }
  },
  "required": [
    "participant_emails",
    "participant_key"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {},
    "update": {},
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}