{
  "name": "HubConversation",
  "type": "object",
  "properties": {
    "participant_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Sorted lowercase emails — both participants"
    },
    "participant_key": {
      "type": "string",
      "description": "Sorted joined emails as deduplication key (e.g. 'a@x.com|b@y.com')"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_message_preview": {
      "type": "string",
      "description": "First 80 chars of last message for inbox preview"
    }
  },
  "required": ["participant_emails", "participant_key"],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "participant_emails": {
        "$contains": "{{user.email}}"
      }
    },
    "update": {
      "participant_emails": {
        "$contains": "{{user.email}}"
      }
    },
    "delete": {
      "participant_emails": {
        "$contains": "{{user.email}}"
      }
    }
  }
}