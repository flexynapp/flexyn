{
  "name": "HubMessage",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "sender_email": {
      "type": "string"
    },
    "recipient_email": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "read_at": {
      "type": "string",
      "format": "date-time",
      "description": "Null until recipient reads"
    }
  },
  "required": ["conversation_id", "sender_email", "recipient_email", "body"],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "sender_email": "{{user.email}}"
        },
        {
          "recipient_email": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "sender_email": "{{user.email}}"
        },
        {
          "recipient_email": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "sender_email": "{{user.email}}"
    }
  }
}