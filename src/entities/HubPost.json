{
  "name": "HubPost",
  "type": "object",
  "properties": {
    "author_email": {
      "type": "string",
      "description": "Author's email; redundant with created_by but used for fast feed queries"
    },
    "author_name": {
      "type": "string",
      "description": "Display name snapshot at post time"
    },
    "post_type": {
      "type": "string",
      "enum": ["status", "achievement", "goal_completed", "workout", "progress_photo"],
      "default": "status"
    },
    "body": {
      "type": "string",
      "description": "Post text content (profanity-filtered)"
    },
    "image_url": {
      "type": "string",
      "description": "Optional uploaded image URL (Base44 file storage)"
    },
    "privacy": {
      "type": "string",
      "enum": ["public", "followers"],
      "default": "public"
    },
    "linked_entity_type": {
      "type": "string",
      "description": "Optional: 'achievement'|'goal'|'workout'|'pr' for system-shared posts"
    },
    "linked_entity_id": {
      "type": "string",
      "description": "Reference to the originating entity for click-through"
    },
    "like_count": {
      "type": "number",
      "default": 0,
      "description": "Denormalized counter, atomic increment on backend"
    },
    "dislike_count": {
      "type": "number",
      "default": 0
    },
    "comment_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": ["author_email", "post_type", "privacy"],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {},
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}