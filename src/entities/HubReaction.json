{
  "name": "HubReaction",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string"
    },
    "reactor_email": {
      "type": "string"
    },
    "reaction": {
      "type": "string",
      "enum": ["like", "dislike"]
    }
  },
  "required": ["post_id", "reactor_email", "reaction"],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {},
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}